{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",

    "module": "esnext",
    "target": "ES2020",

    "declaration": true,

    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}